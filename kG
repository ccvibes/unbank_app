async function jget(url){const ctrl=new AbortController();const t=setTimeout(()=>ctrl.abort(),7000);try{const r=await fetch(url,{cache:'no-store',signal:ctrl.signal});if(!r.ok)throw new Error(r.status);return await r.json();}finally{clearTimeout(t);}}
// each source returns a {code:usd} map; commit validates before writing so a 200-with-garbage response cannot pass as "live"
function commitCrypto(map){if(!(map.BTC>1000))throw new Error('bad crypto');Object.keys(map).forEach(c=>{if(isFinite(map[c])&&map[c]>0)cryptoUsd[c]=map[c];});cryptoUsd.USDT=1;if(!cryptoUsd.USDC)cryptoUsd.USDC=1;}
function commitFiat(map){if(!(map.RUB>1))throw new Error('bad fiat');Object.keys(map).forEach(c=>{if(isFinite(map[c])&&map[c]>0)fiatPerUsd[c]=map[c];});fiatPerUsd.USD=1;}

async function cryptoOKX(){
  const d=await jget('https://www.okx.com/api/v5/market/tickers?instType=SPOT');
  if(!Array.isArray(d.data))throw 0;const t={};d.data.forEach(x=>t[x.instId]=parseFloat(x.last));
  const map={};CRYPTOS.forEach(c=>{if(c.code==='USDT')return;const v=t[c.code+'-USDT'];if(v)map[c.code]=v;});commitCrypto(map);
}
async function cryptoBybit(){
  const d=await jget('https://api.bybit.com/v5/market/tickers?category=spot');
  const list=(d.result&&d.result.list)||[];if(!list.length)throw 0;const t={};list.forEach(x=>t[x.symbol]=parseFloat(x.lastPrice));
  const map={};CRYPTOS.forEach(c=>{if(c.code==='USDT')return;const v=t[c.code+'USDT'];if(v)map[c.code]=v;});commitCrypto(map);
}
async function cryptoBinance(){
  const syms=CRYPTOS.filter(c=>c.binance).map(c=>c.binance);
  const arr=await jget('https://api.binance.com/api/v3/ticker/price?symbols='+encodeURIComponent(JSON.stringify(syms)));
  if(!Array.isArray(arr))throw 0;const t={};arr.forEach(x=>t[x.symbol]=parseFloat(x.price));
  const map={};CRYPTOS.forEach(c=>{if(c.binance&&t[c.binance])map[c.code]=t[c.binance];});commitCrypto(map);
}
async function cryptoCryptoCompare(){
  const d=await jget('https://min-api.cryptocompare.com/data/pricemulti?fsyms='+CRYPTOS.map(c=>c.code).join(',')+'&tsyms=USD');
  if(!d||d.Response==='Error')throw 0;const map={};CRYPTOS.forEach(c=>{if(d[c.code]&&d[c.code].USD)map[c.code]=d[c.code].USD;});commitCrypto(map);
}
async function cryptoCoinGecko(){
  const d=await jget('https://api.coingecko.com/api/v3/simple/price?ids='+CRYPTOS.map(c=>c.id).join(',')+'&vs_currencies=usd');
  const map={};CRYPTOS.forEach(c=>{if(d[c.id]&&d[c.id].usd)map[c.code]=d[c.id].usd;});commitCrypto(map);
}
function applyIcons(){const s=document.getElementById('sel-send');if(s&&s._refresh)s._refresh();renderExchangeList();}
async function fetchCoinImages(){
  try{
    const d=await jget('https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids='+CRYPTOS.map(c=>c.id).join(','));
    if(!Array.isArray(d))return;const idToCode={};CRYPTOS.forEach(c=>idToCode[c.id]=c.code);
    d.forEach(x=>{const code=idToCode[x.id];if(code&&x.image)coinImg[code]=x.image;});
    applyIcons();
  }catch(e){}
}
async function cryptoCoinbase(){
  const d=await jget('https://api.coinbase.com/v2/exchange-rates?currency=USD');
  const r=(d.data&&d.data.rates)||{};const map={};
  CRYPTOS.forEach(c=>{const v=parseFloat(r[c.code]);if(v>0)map[c.code]=1/v;});commitCrypto(map);
}
async function fetchCrypto(){
  for(const fn of [cryptoCoinGecko,cryptoOKX,cryptoBybit,cryptoCoinbase,cryptoBinance,cryptoCryptoCompare]){try{await fn();return true;}catch(e){}}
  return false;
}
async function fiatPrimary(){
  const d=await jget('https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@latest/v1/currencies/usd.json');
  const r=d.usd||{};const map={};FIATS.forEach(f=>{const k=f.code.toLowerCase();if(r[k])map[f.code]=r[k];});commitFiat(map);
}
async function fiatFallback(){
  const d=await jget('https://open.er-api.com/v6/latest/USD');
  if(!d.rates)throw 0;const map={};FIATS.forEach(f=>{if(d.rates[f.code])map[f.code]=d.rates[f.code];});commitFiat(map);
}
async function fiatCoinbase(){
  const d=await jget('https://api.coinbase.com/v2/exchange-rates?currency=USD');
  const r=(d.data&&d.data.rates)||{};const map={};FIATS.forEach(f=>{const v=parseFloat(r[f.code]);if(v>0)map[f.code]=v;});commitFiat(map);
}
async function fetchFiat(){for(const fn of [fiatPrimary,fiatCoinbase,fiatFallback]){try{await fn();return true;}catch(e){}}return false;}

async function refreshRates(){
  refreshDot.classList.remove('spin');void refreshDot.offsetWidth;refreshDot.classList.add('spin');
  const ok=await fetchCrypto();
  ratesLive=ok;liveDot.classList.toggle('stale',!ok);
  recompute();updateStatus();
}
function plural(n,one,few,many){const a=n%10,b=n%100;if(a===1&&b!==11)return one;if(a>=2&&a<=4&&(b<10||b>=20))return few;return many;}
function tick(){countdown--;if(countdown<=0){countdown=30;refreshRates();}updateStatus();}
function updateStatus(){
  if(ratesLive){rateText.textContent='Курс будет обновлён через '+countdown+' '+plural(countdown,'секунду','секунды','секунд');}
  else{rateText.textContent='Резервный курс: нет доступа к биржам';}
}

const toast=document.getElementById('toast');let toastTimer;
function showToast(m){toast.textContent=m;toast.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>toast.classList.remove('show'),3800);}
function buildRequest(){
  const sCrypto=!!cByCode[state.send];
  const cryptoCode=sCrypto?state.send:state.recv,fiatCode=sCrypto?state.recv:state.send;
  const cryptoAmt=parseNum(sCrypto?sendInput.value:recvInput.value)||0;
  const fiatAmt=parseNum(sCrypto?recvInput.value:sendInput.value)||0;
  const price=valueUSD(cryptoCode)/valueUSD(fiatCode);
  return 'Здравствуйте! Хочу купить '+fmt(cryptoAmt,true)+' '+cryptoCode+' за '+fiatCode+' по курсу 1 '+cryptoCode+' = '+fmt(price,false)+' '+fiatCode+'. Сумма: '+fmt(fiatAmt,false)+' '+fiatCode+'.';
}
document.getElementById('continue-btn').addEventListener('click',async()=>{
  const msg=buildRequest();
  try{await navigator.clipboard.writeText(msg);showToast('Запрос скопирован. Вставьте его в чат с менеджером.');}
  catch(e){showToast('Открываю чат. Скопируйте запрос из формы.');}
  window.open('https://t.me/JackietheFox?text='+encodeURIComponent(msg),'_blank','noopener');
});

const exData=[
  {c:'BTC',pair:'Обмен BTC \u2192 RUB',base:0.15,from:'BTC',to:'RUB'},
  {c:'EUR',pair:'Обмен EUR \u2192 BTC',base:15000,from:'EUR',to:'BTC'},
  {c:'ETH',pair:'Обмен ETH \u2192 USD',base:0.32,from:'ETH',to:'USD'},
];
function renderExchangeList(){
  const el=document.getElementById('exchange-list');if(!el)return;el.innerHTML='';
  exData.forEach(row=>{
    const out=row.base*rate(row.from,row.to),toCrypto=!!cByCode[row.to];
    const symbol=row.to==='RUB'?' ₽':(row.to==='USD'?' $':(row.to==='EUR'?' €':' '+row.to));
    const val=toCrypto?(fmt(out,true)+' '+row.to):(fmt(out,false)+symbol);
    const amtLabel=cByCode[row.from]?(row.base+' '+row.from):(fmt(row.base,false)+' '+row.from);
    const c=cByCode[row.c]||{color:'#888',sym:row.c[0]};
    const icon=cByCode[row.c]?(COIN_SVG[row.c]?'<span class="ex-ic coin">'+COIN_SVG[row.c]+'</span>':'<span class="ex-ic" style="background:'+c.color+'">'+c.sym+'</span>'):'<span class="ex-ic" style="background:#eef1f6;font-size:20px">'+(fByCode[row.c]?(fByCode[row.c].e+'<img class="ex-coin-img" src="https://flagcdn.com/w80/'+fByCode[row.c].cc+'.png" alt="" onerror="this.style.display=\'none\'">'):row.c)+'</span>';
    const div=document.createElement('div');div.className='ex-row';
    div.innerHTML=icon+'<div class="ex-mid"><div class="pair">'+row.pair+'</div><div class="amt">'+amtLabel+'</div></div><div class="ex-val">'+val+'</div>';
    el.appendChild(div);
  });
}

