const sendInput=document.getElementById('send-amount'),recvInput=document.getElementById('recv-amount');
const sendHint=document.getElementById('send-hint'),recvHint=document.getElementById('recv-hint');
function boxIsCrypto(side){return !!cByCode[state[side]];}
function recompute(){
  const r=rate(state.send,state.recv);
  const sCrypto=boxIsCrypto('send'),rCrypto=boxIsCrypto('recv');
  if(state.lastEdited==='send'){const a=parseNum(sendInput.value);if(document.activeElement!==recvInput)recvInput.value=fmt(isFinite(a)?a*r:0,rCrypto);}
  else{const a=parseNum(recvInput.value);if(document.activeElement!==sendInput)sendInput.value=fmt(isFinite(a)?a/r:0,sCrypto);}
  const cryptoCode=sCrypto?state.send:state.recv;
  const minTxt='Минимум: '+cByCode[cryptoCode].min+' '+cryptoCode;
  const usdtTxt='1 '+cryptoCode+' = '+fmt(valueUSD(cryptoCode)/valueUSD('USDT'),false)+' USDT';
  if(sCrypto){sendHint.textContent=minTxt;recvHint.textContent=usdtTxt;}
  else{recvHint.textContent=minTxt;sendHint.textContent=usdtTxt;}
  renderExchangeList();
}
sendInput.addEventListener('input',()=>{state.lastEdited='send';recompute();});
recvInput.addEventListener('input',()=>{state.lastEdited='recv';recompute();});
