recvInput.addEventListener('blur',()=>{const a=parseNum(recvInput.value);if(isFinite(a))recvInput.value=fmt(a,boxIsCrypto('recv'));});

function buildSelector(elId,side){
  const root=document.getElementById(elId),pill=root.querySelector('.cur-pill'),panel=root.querySelector('.cur-panel');
  const listEl=root.querySelector('.cur-list'),search=root.querySelector('.cur-search');
  const iconEl=pill.querySelector('[data-role="icon"]'),codeEl=pill.querySelector('[data-role="code"]');
  function isCrypto(){return !!cByCode[state[side]];}
  function curList(){return isCrypto()?CRYPTOS:FIATS;}
  function render(filter){
    const f=(filter||'').trim().toLowerCase();listEl.innerHTML='';const cr=isCrypto();
    curList().filter(it=>!f||it.code.toLowerCase().includes(f)||it.name.toLowerCase().includes(f)).forEach(it=>{
      const opt=document.createElement('div');opt.className='cur-opt'+(it.code===state[side]?' active':'');opt.setAttribute('role','option');
      opt.innerHTML=(cr?cryptoIconHTML(it):flagIconHTML(it))+'<span class="code">'+it.code+'</span><span class="nm">'+it.name+'</span>';
      opt.addEventListener('click',()=>{state[side]=it.code;setPill();recompute();close();});
      listEl.appendChild(opt);
    });
  }
  function setPill(){
    const cr=isCrypto(),it=cr?cByCode[state[side]]:fByCode[state[side]];
    codeEl.textContent=it.code;
    if(cr){const sv=COIN_SVG[it.code];if(sv){iconEl.className='cur-icon coin';iconEl.style.background='transparent';iconEl.innerHTML=sv;}else{iconEl.className='cur-icon';iconEl.style.background=it.color;iconEl.textContent=it.sym;}}
    else{iconEl.className='cur-icon flag';iconEl.style.background='transparent';iconEl.innerHTML=flagImg(it);}
  }
  function open(){closeAll();panel.classList.add('open');pill.classList.add('open');pill.setAttribute('aria-expanded','true');render('');search.value='';setTimeout(()=>search.focus(),30);}
  function close(){panel.classList.remove('open');pill.classList.remove('open');pill.setAttribute('aria-expanded','false');}
  root._close=close;
  root._refresh=function(){setPill();if(panel.classList.contains('open'))render(search.value);};
  pill.addEventListener('click',e=>{e.stopPropagation();panel.classList.contains('open')?close():open();});
  search.addEventListener('input',()=>render(search.value));
  search.addEventListener('click',e=>e.stopPropagation());panel.addEventListener('click',e=>e.stopPropagation());
  setPill();
}
function closeAll(){document.querySelectorAll('.cur-sel').forEach(s=>{if(s._close)s._close();});}
